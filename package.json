{
  "name": "basic-nodejs-mitso",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": ""
  },
  "type": "module",
  "description": "nodejs-mitso",
  "main": "src/server.js",
  "scripts": {
    "start": "nodemon src/server.ts",
    "build": "tsc",
    "lint": "eslint --ext .ts src/"
  },
  "keywords": [
    "rest",
    "node",
    "express",
    "autotest",
    "starter"
  ],
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0 <19"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "./test/setup.js"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "src/**/*.js": [
      "npm run lint"
    ]
  },
  "dependencies": {
    "cross-env": "^7.0.3",
    "dotenv": "^9.0.0",
    "express": "^4.17.1",
    "ts-node": "^10.9.2",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "debug": "^4.3.1",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "lint-staged": "^10.5.4",
    "nodemon": "^3.1.14",
    "prettier": "^2.2.1",
    "typescript": "^5.9.3"
  }
}
